if(NOT EXISTS "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt")
    message(FATAL_ERROR "Cannot find install_manifest.txt")
endif()

file(READ "@CMAKE_CURRENT_BINARY_DIR@/install_manifest.txt" files)

string(REGEX REPLACE "\n" ";" files "${files}")

foreach(file ${files})
    message(STATUS "Removing ${file}")

    if(EXISTS "${file}" OR IS_SYMLINK "${file}")
        file(REMOVE "${file}")
    else()
        message(STATUS "File does not exist: ${file}")
    endif()
endforeach()

# Try to remove directories
file(REMOVE_RECURSE "@CMAKE_INSTALL_PREFIX@/include/libhs-cpp")
file(REMOVE_RECURSE "@CMAKE_INSTALL_PREFIX@/lib/cmake/libhs-cpp")