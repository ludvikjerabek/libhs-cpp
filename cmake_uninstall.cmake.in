if(NOT DEFINED CMAKE_INSTALL_PREFIX)
    message(FATAL_ERROR "CMAKE_INSTALL_PREFIX is not defined")
endif()

file(GLOB_RECURSE files_to_remove
    "${CMAKE_INSTALL_PREFIX}/lib/libhs-cpp*"
    "${CMAKE_INSTALL_PREFIX}/include/libhs-cpp/*"
    "${CMAKE_INSTALL_PREFIX}/lib/cmake/libhs-cpp/*"
)

foreach(file ${files_to_remove})
    message(STATUS "Removing ${file}")
    if(EXISTS "${file}")
        file(REMOVE "${file}")
    endif()
endforeach()

# Try to remove directories
file(REMOVE_RECURSE "${CMAKE_INSTALL_PREFIX}/include/libhs-cpp")
file(REMOVE_RECURSE "${CMAKE_INSTALL_PREFIX}/lib/cmake/libhs-cpp")